   "source": [
    "import numpy as np\n",
    "import matplotlib.pyplot as plt"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "346576ca",
   "metadata": {},
   "outputs": [],
   "source": [
    "p = np.arange(0.01, 1.0, 0.01)\n",
    "H = -p*np.log2(p) - (1-p)*np.log2(1-p)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "747bfc89",
   "metadata": {},
   "outputs": [
