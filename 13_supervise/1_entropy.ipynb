      ]
     },
     "metadata": {},
     "output_type": "display_data"
    }
   ],
   "source": [
    "plt.plot(p, H)\n",
    "plt.xlabel('p')\n",
    "plt.ylabel('H(p)')\n",
    "plt.show()"
   ]
  }
 ],
